pipeline {
    agent {
        kubernetes {
            label 'python311-agent'
            yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: python
    image: python:3.11-alpine
    command: ['cat']
    tty: true
  - name: docker
    image: docker:24
    command: ['cat']
    tty: true
    volumeMounts:
    - name: docker-sock
      mountPath: /var/run/docker.sock
  volumes:
  - name: docker-sock
    hostPath:
      path: /var/run/docker.sock
'''
        }
    }

    environment {
        APP_NAME = 'simple-python'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Prepare Version') {
            steps {
                script {
                    env.VERSION = "v1-${env.BUILD_NUMBER}"
                    env.DOCKER_IMAGE = "${APP_NAME}:${env.VERSION}"

                    echo "Version: ${env.VERSION}"
                }
            }
        }

        stage('Build Image') {
            steps {
                container('docker') {
                    withCredentials([usernamePassword(
                        credentialsId: 'DOCKER_CREDENTIALS',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )]) {
                        sh '''
                            docker build -t $DOCKER_USER/$DOCKER_IMAGE .
                        '''
                    }
                }
            }
        }

        stage('Push Image') {
            steps {
                container('docker') {
                    withCredentials([usernamePassword(
                        credentialsId: 'DOCKER_CREDENTIALS',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )]) {
                        retry(2) {
                            sh '''
                                echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                                docker push $DOCKER_USER/$DOCKER_IMAGE
                                docker logout
                            '''
                        }
                    }
                }
            }
        }

        stage('Update Manifests & Push') {
            steps {
                container('docker') {
                    withCredentials([usernamePassword(
                        credentialsId: 'GIT_CREDENTIALS',
                        usernameVariable: 'GIT_USER',
                        passwordVariable: 'GIT_PASS'
                    ),
                    usernamePassword(
                        credentialsId: 'DOCKER_CREDENTIALS',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )]) {
                        sh '''
                            git config --global --add safe.directory '*'
                            git config --global user.email "jenkins@example.com"
                            git config --global user.name "Jenkins"

                            git checkout master

                            sed -i "s|image: .*/simple-python:.*|image: $DOCKER_USER/simple-python:${VERSION}|g" manifests/cronjob.yaml

                            git add manifests/cronjob.yaml
                            git commit -m "Update image to ${VERSION}"

                            git push origin master
                        '''
                    }
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline completed successfully"
        }
        failure {
            echo "Pipeline failed"
        }
    }
}