pipeline {
    environment {
        APP_NAME = 'simple-python'
        DOCKER_IMAGE = "${APP_NAME}:v1"
    }
    
    agent {
        kubernetes {
            label 'python311-agent'
            yaml '''
                apiVersion: v1
                kind: Pod
                spec:
                    containers:
                    - name: python
                      image: python:3.11-alpine
                      command:
                      - cat
                      tty: true
                    - name: docker
                      image: docker:latest
                      command:
                      - cat
                      tty: true
                      volumeMounts:
                      - name: docker-sock
                        mountPath: /var/run/docker.sock
                    volumes:
                    - name: docker-sock
                      hostPath:
                        path: /var/run/docker.sock
        '''
        }
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.GIT_BRANCH_NAME = sh(script: "git symbolic-ref --short HEAD", returnStdout: true).trim()
                    echo "Current branch is: ${env.GIT_BRANCH_NAME}"
                }
            }
        }
        stage('Install Dependencies') {
            steps {
                container('python') {
                    sh 'pip install --upgrade pip'
                }
            }
        }
        stage('Build Docker Image') {
            steps {
                container('docker') {
                    sh 'docker build -t $DOCKER_IMAGE .'
                }
            }
        }
        stage('Push to Registry') {
            steps {
                container('docker') {
                    withCredentials([usernamePassword(credentialsId: 'DOCKER_CREDENTIALS', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                        sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                        sh 'docker push $DOCKER_IMAGE'
                        sh 'docker logout'
                    }
                }
            }
        }
    }
}