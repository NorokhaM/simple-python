pipeline {
    environment {
        APP_NAME = 'simple-python'
    }
    
    agent {
        kubernetes {
            label 'python311-agent'
            yaml '''
                apiVersion: v1
                kind: Pod
                spec:
                    containers:
                    - name: python
                      image: python:3.11-alpine
                      command:
                      - cat
                      tty: true
                    - name: docker
                      image: docker:latest
                      command:
                      - cat
                      tty: true
                      volumeMounts:
                      - name: docker-sock
                        mountPath: /var/run/docker.sock
                    volumes:
                    - name: docker-sock
                      hostPath:
                        path: /var/run/docker.sock
        '''
        }
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.GIT_BRANCH_NAME = sh(script: "git branch -r --contains HEAD | head -1 | sed 's/.*\\///g' | tr -d ' '", returnStdout: true).trim()
                    echo "Current branch is: ${env.GIT_BRANCH_NAME}"
                    if (env.GIT_BRANCH_NAME == 'master') {
                        env.VERSION = 'v1'
                    } else if (env.GIT_BRANCH_NAME =~ /^v(\d+)$/) {
                        def versionNum = (env.GIT_BRANCH_NAME - 'v').toInteger() + 1
                        env.VERSION = "v${versionNum}"
                    } else {
                        env.VERSION = env.GIT_BRANCH_NAME
                    }
                    echo "Docker version will be: ${env.VERSION}"
                }
            }
        }
        stage('Install Dependencies') {
            steps {
                container('python') {
                    sh 'pip install --upgrade pip'
                }
            }
        }
        stage('Build a Docker Image') {
            steps {
                container('docker') {
                    withCredentials([usernamePassword(credentialsId: 'DOCKER_CREDENTIALS', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                        script {
                            env.DOCKER_IMAGE = "${APP_NAME}:${env.VERSION}"
                        }
                        sh "docker build -t $DOCKER_USER/$DOCKER_IMAGE ."
                    }
                }
            }
        }
        stage('Push Version Branch') {
            steps {
                container('docker') {
                    withCredentials([usernamePassword(credentialsId: 'GIT_CREDENTIALS', usernameVariable: 'GIT_USER', passwordVariable: 'GIT_PASS')]) {
                        sh "git config --global --add safe.directory /home/jenkins/agent/workspace/python-simple/python-simple"
                        sh "git config --global user.email 'jenkins@example.com'"
                        sh "git config --global user.name 'Jenkins'"
                        sh "git push https://${GIT_USER}:${GIT_PASS}@github.com/NorokhaM/simple-python.git HEAD:refs/heads/${env.VERSION}"
                    }
                }
            }
        }
        stage('Push to Registry') {
            steps {
                container('docker') {
                    withCredentials([usernamePassword(credentialsId: 'DOCKER_CREDENTIALS', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                        sh 'echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin'
                        sh 'docker push $DOCKER_USER/$DOCKER_IMAGE'
                        sh 'docker logout'
                    }
                }
            }
        }
    }
}