pipeline {
    agent {
        kubernetes {
            label 'python311-agent'
            yaml '''
apiVersion: v1
kind: Pod
spec:
  containers:
  - name: python
    image: python:3.11-alpine
    command: ['cat']
    tty: true
  - name: docker
    image: docker:24
    command: ['cat']
    tty: true
    volumeMounts:
    - name: docker-sock
      mountPath: /var/run/docker.sock
  volumes:
  - name: docker-sock
    hostPath:
      path: /var/run/docker.sock
'''
        }
    }

    environment {
        APP_NAME = 'simple-python'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Prepare Version') {
            steps {
                script {
                    def branch = env.BRANCH_NAME
                    echo "Branch: ${branch}"

                    if (branch == 'master' || branch == 'main') {
                        env.VERSION = "v1"
                    } else if (branch ==~ /^v\\d+$/) {
                        def versionNum = (branch - 'v').toInteger() + 1
                        env.VERSION = "v${versionNum}"
                    } else {
                        env.VERSION = branch
                    }

                    env.DOCKER_IMAGE = "${APP_NAME}:${env.VERSION}"
                    echo "Version: ${env.VERSION}"
                }
            }
        }

        stage('Build Image') {
            steps {
                container('docker') {
                    withCredentials([usernamePassword(
                        credentialsId: 'DOCKER_CREDENTIALS',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )]) {
                        sh '''
                            docker build -t $DOCKER_USER/$DOCKER_IMAGE .
                        '''
                    }
                }
            }
        }

        stage('Push Image') {
            steps {
                container('docker') {
                    withCredentials([usernamePassword(
                        credentialsId: 'DOCKER_CREDENTIALS',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )]) {
                        sh '''
                            echo $DOCKER_PASS | docker login -u $DOCKER_USER --password-stdin
                            docker push $DOCKER_USER/$DOCKER_IMAGE
                            docker logout
                        '''
                    }
                }
            }
        }

        stage('Update Manifests & Push') {
            steps {
                container('docker') {
                    withCredentials([usernamePassword(
                        credentialsId: 'GIT_CREDENTIALS',
                        usernameVariable: 'GIT_USER',
                        passwordVariable: 'GIT_PASS'
                    )]) {
                        sh '''
                            git config --global user.email "jenkins@example.com"
                            git config --global user.name "Jenkins"

                            git checkout -B ${VERSION}

                            sed -i "s|image: .*/simple-python:.*|image: $DOCKER_USER/simple-python:${VERSION}|g" manifests/cronjob.yaml

                            git add manifests/cronjob.yaml

                            git diff --cached --quiet || git commit -m "Update image to ${VERSION}"

                            git push https://${GIT_USER}:${GIT_PASS}@github.com/NorokhaM/simple-python.git ${VERSION}
                        '''
                    }
                }
            }
        }
    }

    post {
        failure {
            echo "Pipeline failed 💀"
        }
        success {
            echo "Pipeline completed 🚀"
        }
    }
}